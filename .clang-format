# .clang-format
BasedOnStyle: LLVM
IndentWidth: 4
BreakBeforeBraces: Allman

# Форматирование списков — каждый элемент с новой строки
Cpp11BracedListStyle: Block # ← Block вместо false
AlignAfterOpenBracket: Align # ← выравнивание по скобке
BinPackArguments: false
BinPackParameters: OnePerLine # ← каждый параметр с новой строки

# Пробелы внутри скобок
SpaceInEmptyBraces: Never # пустые скобки без пробелов
SpacesInContainerLiterals: true # пробелы внутри { }

# Отключаем упаковку
AllowAllArgumentsOnNextLine: false
AllowAllParametersOfDeclarationOnNextLine: false

ColumnLimit: 100
